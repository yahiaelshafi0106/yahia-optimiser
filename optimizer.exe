#include <iostream>
#include <windows.h>
#include <cstdlib>
#include <chrono>
#include <thread>

using namespace std;

void setBeastMode() {
    system("powercfg /setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c");
    system("del /q /f /s %temp%\\* > nul 2>&1");
    system("ipconfig /flushdns > nul 2>&1");
}

int main() {
    MessageBoxA(NULL, "Yahya Optimizer: System Protected - Beast Mode Starting Now!", "Yahya Optimizer", MB_OK | MB_ICONINFORMATION);

    while (true) {
        setBeastMode();
        cout << "\033[1;32mWindows Performance: OPTIMIZED\033[0m" << endl;
        this_thread::sleep_for(chrono::seconds(10));
    }
    return 0;
}
